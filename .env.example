# POSTGRESQL
POSTGRES_USER=orizon
POSTGRES_PASSWORD=
POSTGRES_DB=orizondb
POSTGRES_PORT=5432

# REDIS: Cache de tokens, emails, clima e respostas da Claude 
REDIS_PASSWORD=
REDIS_PORT=6379

# SEQ — Logs estruturados (http://localhost:5341)
SEQ_PORT=5341
SEQ_API_KEY=

# PROMETHEUS — Coleta de métricas (http://localhost:9090)
PROMETHEUS_PORT=9090

# GRAFANA — Dashboards de observabilidade (http://localhost:3000)
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=

# JWT — mínimo 32 caracteres
JWT_SECRET=
JWT_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=7

# GOOGLE OAUTH 2.0 (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# TRELLO REST API (https://trello.com/power-ups/admin)
TRELLO_API_KEY=
TRELLO_TOKEN=

# ANTHROPIC — Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# SENDGRID — Envio de emails (https://app.sendgrid.com)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@orizonapp.io
SENDGRID_FROM_NAME=Orizon

# OPEN-METEO (https://open-meteo.com/en/docs)
WEATHER_BASE_URL=https://api.open-meteo.com/v1

# ORIZON API - Configurações da API durante desenvolvimento local
API_PORT=5000
WORKER_PORT=5001
ANGULAR_PORT=4200
CORS_ORIGINS=http://localhost:4200