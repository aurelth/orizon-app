# ============================================================
# ORIZON — .gitignore
# Monorepo: .NET 9 Backend + Angular 21 Frontend
# ============================================================
 
 
# ============================================================
# SECRETS E VARIÁVEIS DE AMBIENTE
# Nunca commitar — contém chaves de API, senhas e tokens
# ============================================================
.env
.env.local
.env.production
.env.staging
 
# appsettings com secrets locais do .NET
# O appsettings.json padrão pode ser commitado (sem secrets)
# O .Development.json NUNCA deve ser commitado
src/backend/**/appsettings.Development.json
src/backend/**/appsettings.Production.json
src/backend/**/appsettings.Staging.json
 
# Pasta de secrets do .NET (dotnet user-secrets)
src/backend/**/secrets/
 
 
# ============================================================
# .NET — ARQUIVOS GERADOS PELO COMPILADOR
# Regenerados automaticamente com 'dotnet build' e 'dotnet restore'
# Podem ter centenas de MB — não pertencem ao repositório
# ============================================================
 
# Pastas de output do compilador
[Bb]in/
[Oo]bj/
 
# Arquivos de publicação
[Pp]ublish/
[Pp]ublish[Oo]utput/
 
# Resultados de testes e cobertura
[Tt]est[Rr]esult*/
[Cc]overage*/
*.coverage
*.coveragexml
coverage.json
coverage.opencover.xml
 
# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/
!**/[Pp]ackages/build/
*.nuspec
project.lock.json
project.fragment.lock.json
artifacts/
 
# Entity Framework Core — migrations geradas localmente
# ATENÇÃO: As migrations SÃO commitadas — apenas os snapshots temporários não
src/backend/**/Migrations/*.Designer.cs
 
 
# ============================================================
# VISUAL STUDIO 2022
# Configurações específicas da máquina e preferências pessoais
# Causam conflitos quando mais de uma pessoa trabalha no projeto
# ============================================================
 
# Pasta de configurações do VS (específica por máquina)
.vs/
 
# Arquivos de preferências do usuário
*.user
*.userosscache
*.sln.docstates
*.userprefs
 
# Cache do Visual Studio
*.aps
*.suo
 
# Arquivos de crash e diagnóstico
*.pidb
*.svclog
*.scc
 
 
# ============================================================
# RIDER (JetBrains) — caso use no futuro
# ============================================================
.idea/
*.sln.iml
 
 
# ============================================================
# VS CODE
# Apenas settings pessoais — extensões recomendadas SÃO commitadas
# ============================================================
 
# Settings pessoais (tema, fonte, etc) — não commitar
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
 
# Extensões recomendadas para o projeto — PODE commitar
# .vscode/extensions.json → este arquivo é útil commitar
 
 
# ============================================================
# ANGULAR 21 / NODE.JS
# ============================================================
 
# Dependências — regeneradas com 'npm install'
# Esta pasta pode ter 300MB+ — NUNCA commitar
src/frontend/node_modules/
 
# Output de build de produção — gerado com 'ng build'
src/frontend/dist/
src/frontend/.angular/
 
# Cache do Angular CLI
src/frontend/.angular/cache/
 
# Arquivos de ambiente locais do Angular
src/frontend/src/environments/environment.local.ts
 
# Logs do npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
 
# Cache do npm
.npm/
 
# Relatórios de teste Angular
src/frontend/coverage/
 
 
# ============================================================
# DOCKER
# ============================================================
 
# Override local do Docker Compose com configurações pessoais
# O docker-compose.override.yml padrão É commitado
# Mas overrides locais específicos não devem ser
docker-compose.local.yml
docker-compose.*.local.yml
 
# Dados persistidos pelos containers localmente
# Estes são volumes Docker montados — não pertencem ao repo
infra/data/
infra/postgres-data/
infra/redis-data/
infra/seq-data/
infra/grafana-data/
infra/prometheus-data/
 
 
# ============================================================
# LOGS
# Arquivos de log gerados localmente — nunca commitar
# ============================================================
*.log
logs/
src/backend/**/logs/
 
 
# ============================================================
# SISTEMA OPERACIONAL
# Arquivos gerados automaticamente pelo Windows, macOS e Linux
# Não têm nada a ver com o código
# ============================================================
 
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
 
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
 
# Linux
*~
.fuse_hidden*
.directory
.Trash-*
 
 
# ============================================================
# CERTIFICADOS E CHAVES
# Nunca commitar certificados ou chaves privadas
# ============================================================
*.pfx
*.p12
*.key
*.pem
*.cer
*.crt
!infra/nginx/certs/.gitkeep
 
 
# ============================================================
# ARQUIVOS TEMPORÁRIOS E DE BACKUP
# ============================================================
*.tmp
*.temp
*.bak
*.swp
*.orig
*~
 
 
# ============================================================
# RIDERS DE BUILD E CI LOCAL
# ============================================================
 
# Relatórios de análise de código
BenchmarkDotNet.Artifacts/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
 
 
# ============================================================
# PLAYWRIGHT (testes E2E do Angular)
# ============================================================
src/frontend/test-results/
src/frontend/playwright-report/
src/frontend/blob-report/
src/frontend/playwright/.cache/